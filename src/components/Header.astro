---
import { getEntry } from "astro:content";
const settings = (await getEntry("settings", "site"))!.data;
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
function isActive(href: string) {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
}
---
<header class="sticky top-0 z-40 backdrop-blur-md bg-[color-mix(in_oklab,var(--color-bg)_85%,transparent)] border-b border-[var(--color-line)]">
  <div class="container-x flex items-center justify-between gap-4 py-4">
    <a href="/" class="font-serif text-xl tracking-tight">
      {settings.siteName}
    </a>

    <nav aria-label="Main" class="hidden md:flex items-center gap-6 text-sm">
      {settings.navLinks.map((l) => (
        <a
          href={l.href}
          class:list={["transition-colors hover:text-[var(--color-accent-dark)]", isActive(l.href) && "text-[var(--color-accent-dark)] font-medium"]}
        >
          {l.label}
        </a>
      ))}
      <a href={settings.bookingUrl} class="btn btn-primary text-sm" rel="noopener">
        Book intro call
      </a>
    </nav>

    <details class="md:hidden relative">
      <summary class="list-none cursor-pointer p-2 -mr-2" aria-label="Toggle menu">
        <span class="block w-6 h-px bg-[var(--color-ink)] mb-1.5"></span>
        <span class="block w-6 h-px bg-[var(--color-ink)] mb-1.5"></span>
        <span class="block w-6 h-px bg-[var(--color-ink)]"></span>
      </summary>
      <div class="absolute right-0 top-full mt-2 w-64 rounded-[var(--radius-md)] bg-[var(--color-bg)] shadow-xl border border-[var(--color-line)] p-4 flex flex-col gap-1">
        {settings.navLinks.map((l) => (
          <a href={l.href} class:list={["py-2 px-2 rounded hover:bg-[var(--color-bg-alt)]", isActive(l.href) && "text-[var(--color-accent-dark)] font-medium"]}>
            {l.label}
          </a>
        ))}
        <a href={settings.bookingUrl} class="btn btn-primary mt-2" rel="noopener">Book intro call</a>
      </div>
    </details>
  </div>
</header>
